{
  "expo": {
    "name": "RecyclePro",
    "slug": "RecyclePro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "recyclepro",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.recyclepro.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a2fa8",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.recyclepro.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      "expo-router",
      "./plugins/withOnnxRuntime",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1a2fa8",
          "image": "./assets/images/android-icon-foreground.png",
          "imageWidth": 200
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e8e70320-2216-49f5-97d8-a837b2dcdfe5"
      }
    },
    "owner": "santonijesse"
  }
}
